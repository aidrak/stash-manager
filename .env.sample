# Stash Manager Environment Variables
#
# Copy this file to .env and fill in your own values.
# Do NOT commit the .env file to your repository.

# --- Stash Configuration ---
# The full URL to your Stash instance
STASH_URL=http://your-stash-ip:9999

# Your Stash API key
STASH_API_KEY=

# --- Whisparr Configuration ---
# The full URL to your Whisparr instance
WHISPARR_URL=http://your-whisparr-ip:6969

# Your Whisparr API key
WHISPARR_API_KEY=

# Whisparr root folder
WHISPARR_ROOT_FOLDER=/data

# --- StashDB API Key (Optional) ---
# Your StashDB API key, for fetching metadata
STASHDB_API_KEY=

# --- Media Path (Optional for Docker) ---
# The absolute path to your media files.
# This should match the path your Stash container uses.
MEDIA_PATH=/path/to/your/media
